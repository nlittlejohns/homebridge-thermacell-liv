{
  "name": "homebridge-thermacell-liv",
  "displayName": "Thermacell LIV",
  "type": "module",
  "version": "1.0.0",
  "description": "Homebridge plugin for Thermacell LIV v2 mosquito repeller hubs via ESP RainMaker cloud API.",
  "keywords": [
    "homebridge-plugin",
    "thermacell",
    "liv"
  ],
  "main": "dist/index.js",
  "engines": {
    "node": ">=18.0.0",
    "homebridge": ">=1.6.0"
  },
  "scripts": {
    "build": "rimraf ./dist && tsc",
    "lint": "eslint . --max-warnings=0",
    "prepublishOnly": "npm run lint && npm run build",
    "watch": "npm run build && npm link && nodemon"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "homebridge": "^1.8.0",
    "nodemon": "^3.1.9",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2"
  }
}
